    {
        "id": "inject_login",
        "type": "inject",
        "z": "smart_plant_tab",
        "name": "Đăng nhập",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": true,
        "onceDelay": "2",
        "topic": "",
        "payload": "{\"username\":\"admin\",\"password\":\"123456\"}",
        "payloadType": "json",
        "x": 120,
        "y": 80,
        "wires": [["http_login"]]
    },
    {
        "id": "http_login",
        "type": "http request",
        "z": "smart_plant_tab",
        "name": "POST /api/auth/login",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://localhost:3001/api/auth/login",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [
            {
                "keyType": "Content-Type",
                "keyValue": "",
                "valueType": "other",
                "valueValue": "application/json"
            }
        ],
        "x": 340,
        "y": 80,
        "wires": [["fn_save_token"]]
    },
    {
        "id": "fn_save_token",
        "type": "function",
        "z": "smart_plant_tab",
        "name": "Lưu JWT token",
        "func": "if (msg.payload && msg.payload.token) {\n    flow.set('jwt_token', msg.payload.token);\n    node.status({fill:'green', shape:'dot', text:'Đã đăng nhập'});\n    msg.payload = 'Login OK: ' + msg.payload.user.username;\n} else {\n    node.status({fill:'red', shape:'ring', text:'Login lỗi'});\n    msg.payload = 'Lỗi: ' + JSON.stringify(msg.payload);\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 560,
        "y": 80,
        "wires": [["debug_login"]]
    },
    {
        "id": "debug_login",
        "type": "debug",
        "z": "smart_plant_tab",
        "name": "Login log",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "",
        "statusType": "auto",
        "x": 760,
        "y": 80,
        "wires": []
    },
    {
        "id": "inject_poll",
        "type": "inject",
        "z": "smart_plant_tab",
        "name": "Poll 5s",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": false,
        "onceDelay": "5",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 110,
        "y": 200,
        "wires": [["fn_add_auth_header"]]
    },
    {
        "id": "fn_add_auth_header",
        "type": "function",
        "z": "smart_plant_tab",
        "name": "Thêm JWT header",
        "func": "const token = flow.get('jwt_token');\nif (!token) {\n    node.warn('Chưa đăng nhập - bấm node Đăng nhập trước');\n    return null;\n}\nmsg.headers = { Authorization: 'Bearer ' + token };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 310,
        "y": 200,
        "wires": [["http_status"]]
    },
    {
        "id": "http_status",
        "type": "http request",
        "z": "smart_plant_tab",
        "name": "GET /api/status",
        "method": "GET",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://localhost:3001/api/status",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 530,
        "y": 200,
        "wires": [["fn_parse_status"]]
    },
    {
        "id": "fn_parse_status",
        "type": "function",
        "z": "smart_plant_tab",
        "name": "Tách dữ liệu cảm biến",
        "func": "const latest = msg.payload.latest;\nif (!latest) return null;\n\nreturn [\n    { payload: latest.soilMoisture },\n    { payload: latest.temperature },\n    { payload: latest.humidity },\n    { payload: latest.pumpOn ? 'BƠM: BẬT' : 'BƠM: TẮT' }\n];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 200,
        "wires": [
            ["gauge_soil"],
            ["gauge_temp"],
            ["gauge_humid"],
            ["text_status"]
        ]
    },
