        "func": "const token = flow.get('jwt_token');\nif (!token) return null;\n\nmsg.method = 'POST';\nmsg.url = 'http://localhost:3001/api/control/fan';\nmsg.headers = {\n    'Content-Type': 'application/json',\n    Authorization: 'Bearer ' + token\n};\nmsg.payload = { on: msg.payload };\nreturn msg;",
        "outputs": 1,
