    {
        "id": "fn_control_pump",
        "type": "function",
        "z": "smart_plant_tab",
        "name": "Gọi API bơm",
        "func": "const token = flow.get('jwt_token');\nif (!token) return null;\n\nmsg.method = 'POST';\nmsg.url = 'http://localhost:3001/api/control/pump';\nmsg.headers = {\n    'Content-Type': 'application/json',\n    Authorization: 'Bearer ' + token\n};\nmsg.payload = { on: msg.payload };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 310,
        "y": 360,
        "wires": [["http_control"]]
    },
