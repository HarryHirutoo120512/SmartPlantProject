PORT=3001

# MQTT Broker - cài Mosquitto trên máy tính hoặc dùng broker LAN
MQTT_BROKER_URL=mqtt://localhost:1883

# MongoDB Atlas (Cloud) - tạo free cluster tại https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/smart_plant?retryWrites=true&w=majority

# JWT đăng nhập
JWT_SECRET=doi-chuoi-bi-mat-day-du-32-ky-tu

# Email cảnh báo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL_TO=recipient@gmail.com

# Telegram Push Notification (CN09)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Ngưỡng mặc định
DEFAULT_SOIL_MIN=40
DEFAULT_TEMP_MAX=35
DEFAULT_HUMIDITY_MIN=30
